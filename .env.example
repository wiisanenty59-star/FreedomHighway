# HiddenFreeways — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_PASSWORD=changeme_use_strong_password

# Session secret (use a random 64+ char string)
SESSION_SECRET=changeme_use_a_long_random_string_here

# Database connection (used by api-server)
DATABASE_URL=postgres://hf_user:changeme_use_strong_password@postgres:5432/hiddenfreeways

# App
NODE_ENV=production
PORT=3001
